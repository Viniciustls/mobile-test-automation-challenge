{
  "name": "mobile-test-automation-challenge",
  "version": "1.0.0",
  "description": "Desafio de automação mobile usando WebdriverIO, Appium e Mocha",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Use: npm run test:android ou npm run test:ios\"",
    "test:android": "wdio run config/wdio.android.conf.js",
    "test:ios": "wdio run config/wdio.ios.conf.js",
    "test:android.app": "npm run test:android -- --",
    "test:ios.app": "npm run test:ios -- --",
    "allure:report": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "keywords": [
    "webdriverio",
    "appium",
    "mobile",
    "automation",
    "testing"
  ],
  "author": "Vinicius",
  "license": "ISC",
  "devDependencies": {
    "@wdio/allure-reporter": "^8.16.6",
    "@wdio/appium-service": "^8.16.6",
    "@wdio/cli": "^8.16.6",
    "@wdio/local-runner": "^8.46.0",
    "@wdio/mocha-framework": "^8.16.6",
    "@wdio/spec-reporter": "^8.16.6",
    "allure-commandline": "^2.24.0",
    "appium": "^3.0.0",
    "appium-uiautomator2-driver": "^8.1.0",
    "chai": "^4.3.10",
    "wdio-wait-for": "^3.0.2"
  }
}
